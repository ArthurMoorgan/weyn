{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/uploads/(.*)", "destination": "/api/index" },
    { "source": "/e/:id", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
