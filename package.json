{
  "name": "weyn",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "concurrently -k -n server,web -c green,cyan \"npm:server\" \"npm:web\"",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "web": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "node --test server/*.test.js",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:assets": "npx capacitor-assets generate --ios",
    "cf:dev": "npm run build && wrangler dev",
    "cf:deploy": "npm run build && wrangler deploy",
    "vercel:dev": "vercel dev",
    "vercel:deploy": "vercel deploy --prod"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@clerk/backend": "^3.10.0",
    "@clerk/react": "^6.11.3",
    "@parse/node-apn": "^8.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.63.0",
    "@vercel/blob": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "posthog-node": "^5.39.4",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@emnapi/core": "^1.11.2",
    "@emnapi/wasi-threads": "^1.2.2",
    "@types/google.maps": "^3.58.1",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "playwright": "^1.48.0",
    "typescript": "^5.5.4",
    "vercel": "^54.20.1",
    "vite": "^5.4.6",
    "wrangler": "^4.107.0"
  }
}
