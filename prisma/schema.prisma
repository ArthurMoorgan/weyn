// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  avatarUrl            String?
  googleSub            String?   @unique // legacy Google Sign-In identity, kept for historical rows — no longer written to
  clerkUserId          String?   @unique // real identity now, see server/auth.js
  // Default is ATTENDEE, not ORGANIZER — hosting is granted by *acting* as an
  // organizer (Event.ownerId is set the moment you create your first event),
  // not by the role column. Keeping the default minimal-privilege means a
  // brand-new session token has the least power a bug in `role` checks could
  // grant. ADMIN is manually assigned, never self-assigned.
  role                 Role      @default(ATTENDEE)
  // App-side marker for security-sensitive user changes. Clerk owns real
  // session lifetime; immediate forced sign-out must be done through Clerk.
  tokenVersion         Int       @default(0)
  createdAt            DateTime  @default(now())
  deletedAt            DateTime?
  // Organizer dashboard: prefills for new events (refund policy, capacity,
  // category, etc) so hosting a 10th event doesn't mean retyping the same
  // values. Free-form JSON, not individual columns — this is a UX
  // convenience with no schema-level validation needs, and the exact set of
  // prefillable fields is expected to grow without needing a migration.
  defaultEventSettings Json?

  events                   Event[]
  analyticsEvents          AnalyticsEvent[]
  auditLogs                AuditLog[]
  aiGenerations            AiGenerationLog[]
  agentActions             AgentAction[]
  eventVenues              EventVenue[]
  attendeeProfiles         AttendeeProfile[]
  campaigns                Campaign[]
  expenses                 Expense[]
  mediaAssets              MediaAsset[]
  sponsors                 Sponsor[]
  vendors                  Vendor[]
  automationRules          AutomationRule[]
  workflows                Workflow[]
  eventWorkflows           EventWorkflow[]
  goals                    OrganizerGoal[]
  messageTemplates         MessageTemplate[]
  teamMemberships          EventTeamMember[]         @relation("TeamMembership")
  teamInvitesSent          EventTeamMember[]         @relation("TeamInviter")
  venueTeamMemberships     VenueTeamMember[]         @relation("VenueTeamMembership")
  venueTeamInvitesSent     VenueTeamMember[]         @relation("VenueTeamInviter")
  following                Follow[]                  @relation("Follower")
  followers                Follow[]                  @relation("Following")
  collections              Collection[]
  reportsFiled             Report[]                  @relation("Reporter")
  reportsReviewed          Report[]                  @relation("ReportReviewer")
  venues                   Venue[]
  venueApplications        VenueApplication[]
  webPushSubscriptions     WebPushSubscription[]
  subscription             Subscription?
  marketingLinks           MarketingLink[]
  referralCodes            ReferralCode[]
  brandKit                 OrganizerBrandKit?
  socialAccountConnections SocialAccountConnection[]
  marketingContacts        MarketingContact[]
  socialPosts              SocialPost[]
  emailCampaignSends       EmailCampaignSend[]

  @@index([email])
}

// User → organizer (User who owns events) follow graph. Deliberately
// User-to-User, not User-to-Event — `Event.ownerId` already IS the real
// organizer identity, "organizer" the string field is just a display name.
// Following an organizer surfaces their future events, not just this one.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

// Pinterest-style named list of saved events. Public by default (link is
// shareable) — collaborative editing (multiple owners) is a real future
// step, deliberately not built now since no organizer/user has asked for it
// yet (see the "defer until needed" call on promo codes/UTM this round).
model Collection {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  owner User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([ownerId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  eventId      String
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([collectionId, eventId])
  @@index([eventId])
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  FRAUD
  DUPLICATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

// User-filed reports on an event/organizer/user, reviewed by an ADMIN via
// the moderation queue. entityType/entityId mirrors AuditLog's pattern
// rather than three separate nullable foreign keys.
model Report {
  id         String       @id @default(cuid())
  reporterId String?
  entityType String // "event" | "organizer" | "user"
  entityId   String
  reason     ReportReason
  note       String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  reviewedBy String?
  reviewedAt DateTime?

  reporter User? @relation("Reporter", fields: [reporterId], references: [id])
  reviewer User? @relation("ReportReviewer", fields: [reviewedBy], references: [id])

  @@index([entityType, entityId])
  @@index([status])
}

model Category {
  id    String  @id @default(cuid())
  key   String  @unique // "music", "sports" — matches Event.cat, validated against this table
  label String
  icon  String?
}

model Event {
  id                    String    @id
  title                 String
  organizer             String
  // ownerId is the real, enforced identity (nullable only for pre-auth seed
  // data — see migration notes). `organizer` stays as the display name so
  // existing frontend code and old data keep working unchanged.
  ownerId               String?
  cat                   String
  startsAt              DateTime
  endsAt                DateTime?
  venue                 String
  area                  String
  lat                   Float
  lng                   Float
  distanceKm            Float
  price                 Float
  // Display-only label for `price`/tier/fee amounts across buyer and
  // organizer views — no conversion or FX math anywhere, the stored
  // numbers stay whatever unit they were entered in. Defaults to OMR to
  // match every event created before this column existed.
  currency              String    @default("OMR")
  capacity              Int
  sold                  Int       @default(0)
  image                 String?
  // "50% 30%" CSS background-position — Groq vision's best guess at the
  // photo's focal point, so cover crops (card/detail/dashboard, each a
  // different aspect ratio) don't just default to a dead-center crop that
  // might cut off the actual subject. Null = plain center crop.
  imageFocalPoint       String?
  // Extra photos beyond the single cover `image` — rendered as a swipeable
  // carousel on the event detail page. `image` stays the one used for
  // cards/thumbnails everywhere else, so nothing else needed to change.
  gallery               String[]  @default([])
  color                 String
  glyph                 String
  // "customEventThemes" Pro feature — overrides the app's default purple
  // accent (buttons, active states, the buy bar) on this event's own detail
  // page only. Distinct from `color`/`glyph` above (the card thumbnail
  // fallback when there's no cover image) — null = use the app default.
  accentColor           String?
  // Event Builder 2.0: drafts are real Event rows (not a separate table) so
  // publishing is just flipping a flag, not a data migration — but every
  // public listing query needs `isDraft: false` added alongside its
  // existing `cancelled`/`discoveryStatus` filters. `draftData` holds the
  // wizard's in-progress form state before the row has enough required
  // fields to be a real Event (title/venue/etc are still required at the
  // DB level, so a very early autosave lives here as free-form JSON instead).
  isDraft               Boolean   @default(false)
  isTemplate            Boolean   @default(false)
  draftData             Json?
  venueProfileId        String?
  blurb                 String
  tags                  String[]
  refundPolicy          String
  minAge                Int       @default(0)
  cancelled             Boolean   @default(false)
  ticketingType         String    @default("weyn")
  externalTicketUrl     String?
  organizerContact      String?
  // "organizer_payment" ticketing — organizer supplies EITHER an external
  // payment link (Stripe Payment Link, PayPal.me, etc, buyer redirected
  // straight there) OR free-text transfer/bank details (shown on our own
  // hosted page instead). Both are plain public fields, same visibility
  // level as externalTicketUrl above — neither is a secret the buyer
  // shouldn't see, they need it to actually pay.
  paymentLinkUrl        String?
  transferDetails       String?
  // Automated reminder emails/push, hours-before-start (e.g. [72, 24] = a
  // 3-day and a 1-day reminder) — "scheduledAnnouncements" Pro feature. Empty
  // by default (no automated reminders), distinct from the existing
  // always-on 2h-before push (Booking.reminded) which every event gets
  // regardless of plan. See server/app.js's runReminderScan.
  reminderSchedule      Int[]     @default([])
  sourceUrl             String?
  importedFromInstagram Boolean   @default(false)
  // Custom booking-form builder: an ordered array of extra field defs the
  // organizer collects at booking/checkout time, e.g.
  // [{ id, type: "text"|"email"|"phone"|"dropdown"|"checkbox", label,
  // required, options? }]. Rendered dynamically below the tier/qty picker
  // in EventDetail.tsx/Checkout.tsx; answers land on Booking.customFieldValues.
  // Empty array = no extra fields (the common case), not null, so frontend
  // code can always .map() it directly.
  checkoutFormFields    Json      @default("[]")
  createdAt             DateTime  @default(now())
  deletedAt             DateTime? // soft delete — reads filter this out by default

  // Trust & safety: which discovery surfaces this event is eligible for.
  // Never gates event creation — only how widely it's shown. See
  // server/moderation.js for the pipeline that sets this.
  discoveryStatus DiscoveryStatus @default(PENDING_REVIEW)

  // Organizer Pro — "featured placement" / "priority ranking" (see
  // server/features.js). Existed only as a dead, never-populated field on
  // the frontend Weyn type before this; now a real column an organizer with
  // the featuredPlacement feature can set on their own event.
  featured Boolean @default(false)

  // Invite-only hosting: an event that never appears in public Discovery
  // (GET /api/events) and can't be booked without inviteCode matching —
  // only reachable/bookable via a direct link the organizer shares. The
  // code is never returned by GET /api/events/:id to a non-owner; the
  // frontend only ever has it because it was in the link the organizer
  // sent (?invite=CODE), same pattern as Booking.accessToken elsewhere.
  inviteOnly Boolean @default(false)
  inviteCode String? @unique

  owner             User?              @relation(fields: [ownerId], references: [id])
  venueProfile      EventVenue?        @relation(fields: [venueProfileId], references: [id])
  tiers             Tier[]
  bookings          Booking[]
  tickets           Ticket[]
  teamMembers       EventTeamMember[]
  collectionItems   CollectionItem[]
  moderationResults ModerationResult[]
  promoCodes        PromoCode[]
  waitlistEntries   WaitlistEntry[]
  aiGenerations     AiGenerationLog[]
  campaigns         Campaign[]
  expenses          Expense[]
  mediaAssets       MediaAsset[]
  sponsors          Sponsor[]
  vendors           Vendor[]
  feedback          EventFeedback[]
  automationRules   AutomationRule[]
  eventWorkflows    EventWorkflow[]
  floorPlan         FloorPlan?
  marketingLinks    MarketingLink[]
  referralCodes     ReferralCode[]
  socialPosts       SocialPost[]
  checkIns          CheckIn[]
  shifts            EventShift[]
  budgets           Budget[]

  @@index([organizer])
  @@index([featured])
  @@index([startsAt])
  @@index([ownerId])
  @@index([venueProfileId])
  @@index([discoveryStatus])
}

enum DiscoveryStatus {
  PENDING_REVIEW // published, rule engine/AI review in flight — visible only via direct link
  APPROVED // full discovery feed, search, category browse
  DISCOVERY_LIMITED // direct link + organizer profile only, excluded from main feed/trending
  MANUAL_REVIEW // queued for a human — same visibility as DISCOVERY_LIMITED while pending
  DISCOVERY_BLOCKED // hidden everywhere, including direct link
}

// One row per moderation pass (rule engine and/or AI), so an event's full
// review history is auditable, not just its current status. See
// server/moderation.js's runModerationPipeline.
model ModerationResult {
  id              String          @id @default(cuid())
  eventId         String
  triggeredBy     String // "publish" | "edit" | "manual_recheck"
  ruleFlags       String[] // deterministic rule-engine flags that fired (soft-fail/warning)
  qualityScore    Int?
  trustScore      Int?
  spamRisk        Int?
  fraudRisk       Int?
  aiConfidence    Int?
  aiFlags         String[]
  reasoning       String[]
  aiConfigured    Boolean         @default(false) // false = heuristic fallback was used, not a real AI call
  resultingStatus DiscoveryStatus
  createdAt       DateTime        @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

enum TeamRole {
  // Same event powers as the owner (edit/cancel/duplicate/attendees/
  // marketing) except transferring ownership or managing the team itself —
  // that stays owner (or platform ADMIN) only, so a MANAGER can't remove the
  // person who invited them.
  MANAGER
  // Check-in only — the door-staff role. Deliberately can't see revenue,
  // attendee emails, or edit the event; scope matches what someone handed a
  // phone at the entrance actually needs.
  STAFF
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Grants a User (or a not-yet-registered email) scoped access to one Event
// without making them its owner. Invites are copy-link based, not emailed —
// Weyn has no transactional email provider configured; the organizer shares
// the link themselves (WhatsApp, email, however). userId is null until the
// invitee signs in and accepts, at which point it's filled in and the
// invite becomes the durable record of that person's access to this event.
model EventTeamMember {
  id           String           @id @default(cuid())
  eventId      String
  invitedEmail String
  userId       String?
  role         TeamRole
  status       TeamInviteStatus @default(PENDING)
  // Unguessable, single-use — the accept link is /invite/:inviteToken.
  // Cleared (set null) once accepted so a leaked old link can't be reused
  // to re-grant access after acceptance.
  inviteToken  String?          @unique @default(cuid())
  invitedBy    String
  createdAt    DateTime         @default(now())
  acceptedAt   DateTime?
  // Finer-grained than role alone — e.g. a STAFF member restricted to
  // "scannerOnly" can't see attendee lists, only the check-in scanner.
  // Empty array = full access implied by `role` (STAFF=check-in, MANAGER=all).
  permissions  String[]         @default([])

  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User?        @relation("TeamMembership", fields: [userId], references: [id])
  inviter User         @relation("TeamInviter", fields: [invitedBy], references: [id])
  shifts  EventShift[]

  // one active (non-revoked) membership per person per event — re-inviting
  // after a revoke creates a new row rather than fighting a unique index
  @@index([eventId])
  @@index([userId])
  @@index([invitedEmail])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String // "event_view" | "event_save" | "search" | "category_click" | "profile_visit"
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([type, createdAt])
  @@index([entityId])
}

model Tier {
  id            String    @id @default(cuid())
  eventId       String
  name          String
  price         Float
  capacity      Int
  sold          Int       @default(0)
  // Advanced ticketing: "standard" | "vip" | "group" | "family" | "membership" | "donation"
  kind          String    @default("standard")
  minQty        Int? // group/family bundle minimum quantity per purchase
  includesMerch Boolean   @default(false)
  // Private/hidden tiers — never listed on the public event page; reachable
  // only via a direct link (?tier=id) that also supplies the password if set.
  hidden        Boolean   @default(false)
  password      String?
  releaseAt     DateTime? // timed release — not purchasable/visible before this

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([eventId])
}

enum BookingStatus {
  pending
  paid
  cancelled
  expired
}

model Booking {
  id                String        @id @default(cuid())
  eventId           String
  tierId            String?
  status            BookingStatus @default(pending)
  deviceId          String?
  email             String?
  name              String?
  qty               Int           @default(1)
  accessToken       String?       @unique
  bookedAt          DateTime      @default(now())
  reminded          Boolean       @default(false)
  // "organizer_payment" flow only — the attendee's own claim that they sent
  // the transfer/paid the link, BEFORE the organizer has actually confirmed
  // it (status stays "pending" until they do). Purely informational, surfaced
  // to the organizer so they know a claim is waiting — never trusted as proof
  // of payment on its own.
  claimedPaidAt     DateTime?
  // Which of the event's reminderSchedule offsets (hours-before-start) have
  // already been sent for this booking — prevents the scan from re-sending
  // the same T-3d reminder on every 5-minute tick once it's within window.
  autoRemindersSent Int[]         @default([])
  // Promotion Center: captured from ?utm_source=... on the event page at the
  // moment of booking (see EventDetail.tsx) — null means direct/no campaign.
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  // Marketing Hub referral program: which organizer-issued ReferralCode (if
  // any) this booking was attributed to, captured from ?ref=CODE the same
  // way utmSource/etc are captured from ?utm_source=... — null means this
  // booking wasn't referred.
  referredByCodeId  String?
  // Seat-mode events only (see FloorSeat): the specific seats claimed
  // ("reserved") at POST /checkout time, before payment is confirmed —
  // carried through to the webhook so it can create the matching
  // Ticket.seatId row(s) once the booking actually gets paid. Empty for
  // every non-seated/free booking (those seats, if any, go straight onto
  // the Ticket row at book() time instead — see POST /:id/book).
  seatIds           String[]         @default([])
  // Answers to the event's Event.checkoutFormFields, keyed by field id:
  // { [fieldId]: string | boolean }. Empty object for events with no
  // custom fields configured.
  customFieldValues Json             @default("{}")

  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier            Tier?            @relation(fields: [tierId], references: [id])
  payment         Payment?
  tickets         Ticket[]
  tableAssignment TableAssignment?
  referredByCode  ReferralCode?    @relation("ReferredBookings", fields: [referredByCodeId], references: [id])

  @@index([eventId])
  @@index([deviceId])
  @@index([status])
  @@index([referredByCodeId])
}

enum PaymentStatus {
  pending
  paid
  failed
}

model Payment {
  id             String        @id @default(cuid())
  bookingId      String        @unique
  paytabsTranRef String?       @unique
  // NOTE: a `stripeSessionId` field used to be declared here. It only ever
  // existed on the old Neon DB as untracked drift (added by a migration that
  // never made it into migrations/), was unreferenced by any code (no Stripe
  // integration exists), and does NOT exist on the migration-built Supabase
  // DB the app now runs on. Keeping it in the schema made every query that
  // joins `payment` (e.g. getBooking → ticket viewing, checkout confirm)
  // fail with "column Payment.stripeSessionId does not exist" after the
  // Supabase cutover. Removed so the schema matches the real DB.
  amount         Float
  status         PaymentStatus @default(pending)
  rawWebhook     Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// One row per admitted seat (booking.qty can be >1) — the actual unit that
// gets scanned at the door. Deliberately separate from Booking so a
// multi-ticket purchase can't be checked in "all at once" by reusing a
// single shared code, and so a leaked/screenshotted code only ever admits
// one person, once.
model Ticket {
  id          String    @id @default(cuid())
  bookingId   String
  eventId     String
  // Long, random, unguessable — rendered as a QR code client-side. Not
  // sequential/derivable from the booking id, so scraping booking IDs can't
  // be used to forge admission.
  code        String    @unique @default(cuid())
  checkedInAt DateTime?
  checkedInBy String? // User.id of the organizer/staff who scanned it
  createdAt   DateTime  @default(now())
  // Set only for events whose FloorPlan mode is "seat" — the specific seat
  // this ticket was assigned at checkout. Null for every non-seated event
  // (the overwhelming majority), so this stays a plain nullable FK rather
  // than forcing every event into the seat-picking flow.
  seatId      String?   @unique

  // ---- Ticket transfers: reassigning a ticket to a different attendee ----
  // Purely informational re-labeling — the same Ticket row (and its `code`)
  // keeps admitting whoever holds the code; this just records who it's
  // supposed to belong to now, for the attendee list / re-sent confirmation.
  transferredToEmail String?
  transferredAt      DateTime?
  transferredBy      String? // User.id of the organizer/staff who actioned it

  booking  Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  event    Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seat     FloorSeat? @relation(fields: [seatId], references: [id])
  checkIns CheckIn[]

  @@index([bookingId])
  @@index([eventId])
}

// ---- QR check-in scanning: append-only log of every scan attempt, distinct
// from Ticket.checkedInAt/checkedInBy (which just tracks the current
// admitted/not-admitted state) — this records EVERY scan including
// duplicates/invalid codes, for the live "checked in vs total" count and a
// per-event history view.
enum CheckInStatus {
  VALID
  DUPLICATE
  INVALID
}

model CheckIn {
  id        String        @id @default(cuid())
  eventId   String
  ticketId  String?
  bookingId String?
  scannedAt DateTime      @default(now())
  scannedBy String? // User.id of the organizer/staff who scanned
  method    String        @default("qr") // "qr" | "manual"
  status    CheckInStatus

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([ticketId])
  @@index([eventId, status])
}

// ---- Staff shift scheduling ----
model EventShift {
  id           String   @id @default(cuid())
  eventId      String
  teamMemberId String
  role         String?
  startTime    DateTime
  endTime      DateTime
  notes        String?
  createdAt    DateTime @default(now())

  event      Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamMember EventTeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([teamMemberId])
}

// ---- Budget tracking with alerts — loosely linked to Expense by matching
// `category` strings (not a hard FK, since expenses are freeform-category
// and a budget line can exist before any expense is logged against it) ----
model Budget {
  id              String   @id @default(cuid())
  eventId         String
  category        String
  allocatedAmount Float
  currency        String   @default("OMR")
  createdAt       DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, category])
  @@index([eventId])
}

// Append-only trail for anything that mutates state on someone else's
// behalf or destroys data — moderation, cancellation, check-in. Not meant
// to be edited or deleted by app code; exists purely for after-the-fact
// "who did what" review (disputes, fraud investigation, abuse reports).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String // e.g. "event.cancel", "event.moderate", "ticket.checkin"
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// DEAD as of the OneSignal migration (see server/onesignal.js) — OneSignal
// manages device registration/subscriptions itself client-side, so nothing
// writes to this model anymore (server/app.js's old POST /api/push/register
// was removed). Left in place rather than migrated away — db.js's
// upsertPushToken/tokenForDevice/tokensForUser still exist too. Safe to drop
// in a later cleanup once OneSignal has been live for a while.
model PushToken {
  id           String   @id @default(cuid())
  deviceId     String   @unique
  secretHash   String?
  token        String
  platform     String   @default("ios")
  // Set when the device registers while signed in — lets pushes target a
  // person (e.g. venue-approval) instead of only a deviceId from a booking.
  userId       String?
  registeredAt DateTime @default(now())

  @@index([userId])
}

// DEAD as of the OneSignal migration, same as PushToken above — OneSignal's
// web SDK manages its own subscriptions; the old POST /api/push/web-subscribe
// / web-unsubscribe routes that wrote here were removed from server/app.js.
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MarketingAsset {
  eventId           String   @id
  instagram         String
  whatsapp          String
  telegram          String
  twitter           String
  instagramStory    String?
  whatsappBroadcast String?
  schedule          Json?
  generatedAt       DateTime @default(now())
  aiGenerated       Boolean  @default(false)
  // Marketing Hub: paid ad-platform copy and outreach templates, all
  // additive/nullable like instagramStory/whatsappBroadcast above — old
  // rows stay valid until the organizer next regenerates. googleAd*/metaAd*
  // are arrays of {headline, description} variants (character-limit-aware,
  // see server/marketing.js), not single strings, since ad platforms
  // expect several headline/description options to rotate.
  googleAdVariants  Json?
  metaAdVariants    Json?
  pressRelease      String?
  influencerDm      String?
}

// Marketing Hub: UTM-tagged trackable links an organizer generates for one
// event (e.g. one per channel/campaign) — clicks are counted via the
// existing /api/events/:id link-through redirect the frontend already
// appends utm_* params for on booking (see Booking.utmSource etc); this
// table is just the organizer-facing "here are the links I made" list, not
// a new tracking pixel.
model MarketingLink {
  id          String   @id @default(cuid())
  eventId     String
  organizerId String
  label       String
  utmSource   String
  utmMedium   String
  utmCampaign String
  url         String
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer User  @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([organizerId])
}

// Marketing Hub: simple referral tracking, no real payout mechanism (per
// spec) — an attendee gets a shareable code, referred bookings tally
// against it for a leaderboard/perk credit the organizer decides on
// manually. One row per attendee-per-event; `code` is globally unique so it
// can be used as a URL param (?ref=CODE) without also needing eventId.
model ReferralCode {
  id            String   @id @default(cuid())
  eventId       String
  organizerId   String
  code          String   @unique
  ownerName     String?
  ownerEmail    String?
  referralCount Int      @default(0)
  createdAt     DateTime @default(now())

  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer User      @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  bookings  Booking[] @relation("ReferredBookings")

  @@index([eventId])
  @@index([organizerId])
}

// Marketing Hub: per-organizer branding preferences threaded into the AI
// copy prompt (server/marketing.js) so generated copy stays on-brand.
// Deliberately its own table rather than more fields on User — this is
// optional, organizer-dashboard-only settings, same reasoning as
// EventVenue being split out from Event.
model OrganizerBrandKit {
  organizerId  String   @id
  logoUrl      String?
  primaryColor String?
  toneOfVoice  String? // free text, e.g. "playful and casual" / "polished and formal"
  updatedAt    DateTime @updatedAt

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)
}

// ---- Organizer social/email growth suite: real connect-and-send, not just
// copy-to-paste (that's MarketingAsset/googleAdVariants/etc above). Parked
// integration pattern, same as server/email.js's Resend wrapper and
// handoff.md §4.5's Stripe plan — every route here is fully code-complete
// but gated on env vars (META_APP_ID/META_APP_SECRET/META_REDIRECT_URI/
// SOCIAL_TOKEN_ENC_KEY) that are empty in every environment today, so none
// of it can fire until someone deliberately sets them in prod. ----

// One row per organizer per provider (organizer-level, not per-event —
// Instagram/Facebook posting publishes from the organizer's own connected
// Page/IG Business Account regardless of which event the copy is for).
// accessTokenEnc is AES-256-GCM ciphertext (see server/crypto-secrets.js),
// never a plaintext token at rest — same reasoning PayTabs webhook
// signatures get timing-safe comparison in server/payments.js: a token
// leak here is a real account-takeover-adjacent risk (posting-as-organizer
// on their real Instagram/Facebook), not just an inconvenience.
// Dual-owned: exactly one of userId (organizer) / venueId (venue) is set,
// never both — a Venue here is owned by a single User (Venue.ownerId), so
// rather than a venue-specific sibling model (which SocialPost/
// MarketingContact/EmailCampaignSend below use instead, since those really
// are list/history data, not a 1:1 connection record) this one just grows
// a second optional FK: a connection is a single row keyed by "the thing
// posting" either way, and duplicating the OAuth-token-storage shape+
// crypto handling for an identical connection record bought nothing.
// Enforced in code (server/app.js), not the DB: whichever route creates
// this (organizer's /api/me/social-accounts/meta/callback vs. venue's
// /api/venues/:id/social-accounts/meta/callback) sets only its own FK.
model SocialAccountConnection {
  id                  String    @id @default(cuid())
  userId              String?
  venueId             String?
  provider            String // "meta" (Instagram + Facebook via Meta Graph API) — only provider today, room to add more later
  accessTokenEnc      String // AES-256-GCM ciphertext, see server/crypto-secrets.js encryptSecret()
  tokenExpiresAt      DateTime?
  igBusinessAccountId String? // resolved once at connect-time from the chosen Facebook Page
  pageId              String?
  pageName            String?
  connectedAt         DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([venueId, provider])
  @@index([userId])
  @@index([venueId])
}

// ---- Venue-owned siblings of SocialPost/MarketingContact/EmailCampaignSend
// above. Kept as separate models (rather than adding a nullable venueId to
// the organizer-scoped ones) because those three are list/history data
// scoped to "organizerId" as a required FK with organizer-only unique
// constraints (e.g. MarketingContact's @@unique([organizerId, email])) —
// bolting an optional venueId alongside would mean every existing query,
// index, and unique constraint on those models would need an
// organizerId-or-venueId branch throughout server/app.js's organizer
// routes, for no shared benefit (a venue guest list and an organizer's
// ticket-buyer list are never the same rows). A connection record
// (above) is different: it's really one MetaConnection concept regardless
// of who owns it, so growing one FK there was cheaper than duplicating
// OAuth/token-storage code.

model VenueSocialPost {
  id             String   @id @default(cuid())
  venueId        String
  provider       String // "instagram" today
  externalPostId String?
  copy           Json // snapshot of exactly what was posted (caption + which image url)
  status         String   @default("posted") // "posted" | "failed"
  error          String?
  postedAt       DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

// Venue-owned guest-marketing subscriber list — distinct from
// Reservation.guestEmail (transactional, per-booking, never opted in to
// marketing email) and from VenueGuestNote (CRM tags, not a mailing
// list). Real unsubscribeToken, same generation pattern as
// MarketingContact above — CAN-SPAM/GDPR-style compliance is required for
// real bulk email regardless of which dashboard sends it.
model VenueMarketingContact {
  id               String   @id @default(cuid())
  venueId          String
  email            String
  name             String?
  subscribed       Boolean  @default(true)
  source           String   @default("manual") // "manual" | "csv_import"
  tags             String[] @default([])
  unsubscribeToken String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, email])
  @@index([venueId])
}

// One row per real bulk-email send to a venue's VenueMarketingContact list
// (mirrors EmailCampaignSend above) — separate from Campaign (which
// already records the guest-segment win-back email flow) since a
// campaign send targets Reservation-derived segments, this targets the
// venue's opted-in marketing list specifically.
model VenueEmailCampaignSend {
  id             String   @id @default(cuid())
  venueId        String
  subject        String
  bodyHtml       String
  recipientCount Int      @default(0)
  sentAt         DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

// Record of an actual publish to Instagram (container-create → publish,
// see server/social-posting.js) — lets the UI show post history and, more
// importantly, block an accidental double-post of the same drafted copy
// for the same event (see the route's pre-check in server/app.js).
model SocialPost {
  id             String   @id @default(cuid())
  eventId        String
  organizerId    String
  provider       String // "instagram" today
  externalPostId String? // Graph API media/publish id, once known
  copy           Json // snapshot of exactly what was posted (caption + which image url)
  status         String   @default("posted") // "posted" | "failed"
  error          String?
  postedAt       DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer User  @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([organizerId])
}

// Organizer-owned (not event-owned) email subscriber list — distinct from
// ticket-buyer Booking.email, which is transactional/per-event and was
// never opted in to marketing email. This is the real, separately-
// consented list real bulk email requires. unsubscribeToken is a real
// one-click-unsubscribe credential (crypto.randomBytes, same generation
// pattern as EventTeamMember/PromoCode invite codes elsewhere in this
// schema), not a decorative link — CAN-SPAM/GDPR-style compliance is a
// legal requirement for real bulk email, not an optional nicety.
model MarketingContact {
  id               String    @id @default(cuid())
  organizerId      String
  email            String
  name             String?
  subscribed       Boolean   @default(true)
  source           String    @default("manual") // "manual" | "csv_import"
  tags             String[]  @default([])
  // Birthday/anniversary reminder automation: optional date-of-birth (year
  // may be a placeholder if unknown — only month/day are used for the
  // "contact_birthday" AutomationRule trigger match).
  birthday         DateTime?
  unsubscribeToken String    @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([organizerId, email])
  @@index([organizerId])
}

// One row per real bulk-email send via sendEmail()/Resend — history +
// recipient count for the Marketing Hub UI, mirroring how Campaign already
// records the per-event notify-attendees flow (this is the organizer-owned
// subscriber-list equivalent, not a replacement for Campaign).
model EmailCampaignSend {
  id             String   @id @default(cuid())
  organizerId    String
  eventId        String? // nullable — a send can be about one event's copy but still goes out to the organizer-wide list, not per-event recipients
  subject        String
  bodyHtml       String
  recipientCount Int      @default(0)
  sentAt         DateTime @default(now())

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
}

// ---- Reservations (tables/spots at restaurants, cafes, lounges, rooftops,
// beach clubs, experience venues) — deliberately separate from Event/Booking
// ticketing above; a Venue is a standing place with recurring availability,
// not a one-off scheduled happening.
model Venue {
  id                 String   @id @default(cuid())
  name               String
  category           String // "restaurant" | "cafe" | "lounge" | "rooftop" | "beach_club" | "experience"
  description        String
  venue              String
  area               String
  lat                Float
  lng                Float
  distanceKm         Float
  coverImage         String?
  photos             String[]
  priceRange         String? // "$" | "$$" | "$$$"
  tags               String[]
  ownerId            String?
  verified           Boolean  @default(false)
  subscriptionTier   String?
  subscriptionStatus String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner                    User?                     @relation(fields: [ownerId], references: [id])
  slots                    VenueAvailabilitySlot[]
  reservations             Reservation[]
  guestNotes               VenueGuestNote[]
  campaigns                Campaign[]
  automationRules          AutomationRule[]
  workflows                Workflow[]
  floorPlan                FloorPlan?
  marketingLinks           VenueMarketingLink[]
  loyaltyProfiles          VenueLoyalty[]
  brandKit                 VenueBrandKit?
  socialAccountConnections SocialAccountConnection[]
  socialPosts              VenueSocialPost[]
  marketingContacts        VenueMarketingContact[]
  emailCampaignSends       VenueEmailCampaignSend[]
  waitlistEntries          VenueWaitlistEntry[]
  teamMembers              VenueTeamMember[]

  @@index([ownerId])
  @@index([category])
}

// Venue-scoped team access — mirrors EventTeamMember exactly (same TeamRole /
// TeamInviteStatus enums, same copy-link invite flow, same "userId null until
// accepted, inviteToken cleared on accept" model). STAFF is front-of-house /
// day-to-day, MANAGER runs the venue except managing the team itself (owner
// only). See EventTeamMember above for the reasoning behind each field.
model VenueTeamMember {
  id           String           @id @default(cuid())
  venueId      String
  invitedEmail String
  userId       String?
  role         TeamRole
  status       TeamInviteStatus @default(PENDING)
  inviteToken  String?          @unique @default(cuid())
  invitedBy    String
  createdAt    DateTime         @default(now())
  acceptedAt   DateTime?
  permissions  String[]         @default([])

  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user    User? @relation("VenueTeamMembership", fields: [userId], references: [id])
  inviter User  @relation("VenueTeamInviter", fields: [invitedBy], references: [id])

  @@index([venueId])
  @@index([userId])
  @@index([invitedEmail])
}

// ---- venue reservation waitlist (fully-booked slot → guest joins a
// waitlist, gets notified/promoted when a table opens up). Deliberately a
// separate model from the per-event WaitlistEntry above (see that model's
// comment) and from LandingWaitlistSignup — this one is scoped to a real
// Venue + a requested date/time, and can be promoted straight into a real
// Reservation row. ----
enum VenueWaitlistStatus {
  WAITING
  NOTIFIED
  CONVERTED
  EXPIRED
  CANCELLED
}

model VenueWaitlistEntry {
  id                     String              @id @default(cuid())
  venueId                String
  guestName              String
  guestEmail             String
  guestPhone             String?
  partySize              Int
  requestedDate          DateTime
  requestedTimeWindow    String // free-text, e.g. "19:00" or "19:00-21:00"
  notes                  String?
  status                 VenueWaitlistStatus @default(WAITING)
  // Higher = notified/promoted first when a slot frees up. Plain guest
  // joins default to 0; an owner can bump a VIP up manually from the
  // dashboard.
  priority               Int                 @default(0)
  notifiedAt             DateTime?
  convertedReservationId String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([venueId, status])
  @@index([requestedDate])
}

model VenueAvailabilitySlot {
  id        String   @id @default(cuid())
  venueId   String
  dayOfWeek Int
  startTime String
  endTime   String
  capacity  Int
  createdAt DateTime @default(now())

  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([venueId])
}

model Reservation {
  id         String   @id @default(cuid())
  venueId    String
  slotId     String?
  guestName  String
  guestEmail String
  guestPhone String?
  partySize  Int
  date       DateTime
  time       String
  status     String   @default("pending") // "pending" | "confirmed" | "cancelled" | "seated" | "no_show"
  // Owner-entered reservations (phone bookings, walk-ins) skip the guest
  // submission flow entirely — flagged here so the dashboard can show how a
  // booking arrived instead of assuming everything came from a guest form.
  source     String   @default("guest") // "guest" | "manual"
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  venue           Venue                  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slot            VenueAvailabilitySlot? @relation(fields: [slotId], references: [id])
  tableAssignment TableAssignment?

  @@index([venueId])
  @@index([slotId])
  @@index([status])
}

// ============================================================
// Table/seat picking — one reusable floor-plan system shared by Venues
// (reservations) and Events (assigned-seating ticketed events like a wine
// tasting or comedy night), rather than two parallel implementations.
// `mode` is chosen per venue/event by the organizer:
//   "table" — guests/staff assign a whole table (most restaurants/lounges)
//   "seat"  — individual seats are assigned (theater-style ticketed events)
// ============================================================

model FloorPlan {
  id        String   @id @default(cuid())
  venueId   String?  @unique
  eventId   String?  @unique
  mode      String   @default("table") // "table" | "seat"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue    Venue?         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event    Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sections FloorSection[]
  tables   FloorTable[]
}

model FloorSection {
  id          String   @id @default(cuid())
  floorPlanId String
  name        String // "Indoor" | "Rooftop" | "Patio" — free text, organizer-defined
  createdAt   DateTime @default(now())

  floorPlan FloorPlan    @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  tables    FloorTable[]

  @@index([floorPlanId])
}

// One physical table (or, in "seat" mode, one row/cluster that FloorSeat
// rows belong to — e.g. a "Row A" pseudo-table holding 12 theater seats).
// x/y/width/height/rotation drive the visual layout editor; label/capacity
// drive assignment regardless of whether the canvas has been laid out yet.
model FloorTable {
  id          String   @id @default(cuid())
  floorPlanId String
  sectionId   String?
  label       String // "Table 4", "Row A"
  shape       String   @default("rect") // "rect" | "circle"
  x           Float    @default(0)
  y           Float    @default(0)
  width       Float    @default(80)
  height      Float    @default(80)
  rotation    Float    @default(0)
  minCapacity Int      @default(1)
  maxCapacity Int
  status      String   @default("available") // "available" | "reserved" | "occupied" | "needs_cleaning" | "maintenance"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floorPlan   FloorPlan              @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  section     FloorSection?          @relation(fields: [sectionId], references: [id])
  seats       FloorSeat[]
  assignments TableAssignmentTable[]

  @@index([floorPlanId])
  @@index([sectionId])
}

// Only populated when the owning FloorPlan's mode is "seat" — one row per
// physical seat, assignable to a single Ticket (see Ticket.seatId below).
model FloorSeat {
  id      String  @id @default(cuid())
  tableId String
  index   Int // seat number within its table/row
  label   String? // e.g. "A1" — overrides the auto "index" label if set
  status  String  @default("available") // "available" | "reserved" | "occupied"

  table  FloorTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  ticket Ticket?

  @@index([tableId])
}

// One assignment = one party seated at one moment — links to a Reservation
// (venue booking) OR a Booking (event booking, rare but supported for
// table-mode events), and to one-or-more FloorTables via the join table
// below. Table MERGE is "one assignment, many tables"; table SPLIT is "one
// table, many assignments at different times" — both fall out of this same
// shape for free, no separate merge/split concept needed.
model TableAssignment {
  id            String   @id @default(cuid())
  reservationId String?  @unique
  bookingId     String?  @unique
  date          DateTime
  time          String
  partySize     Int
  createdAt     DateTime @default(now())

  reservation Reservation?           @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  booking     Booking?               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tables      TableAssignmentTable[]
}

model TableAssignmentTable {
  id           String @id @default(cuid())
  assignmentId String
  tableId      String

  assignment TableAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  table      FloorTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, tableId])
  @@index([tableId])
}

// Notes an owner keeps on a specific guest at their venue — independent of
// any single Reservation (a guest with 5 past visits should have one running
// note, not 5 disconnected ones). Deliberately its own tiny table rather than
// a field bolted onto Reservation, since it's keyed on (venue, guest), not
// (venue, guest, visit).
model VenueGuestNote {
  id         String   @id @default(cuid())
  venueId    String
  guestEmail String
  note       String
  // Real CRM tagging (VIP, regular, allergy-aware, ...) — free-text tags an
  // owner defines themselves, not a fixed enum, since every venue's own
  // vocabulary differs. Segment-targeted marketing (see Campaign.segment)
  // matches against these.
  tags       String[] @default([])
  updatedAt  DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, guestEmail])
}

// A venue owner's request to be onboarded onto reservation hosting —
// distinct from Venue itself, which only gets created once the Weyn team
// approves an application by hand. See POST /api/venue-applications.
model VenueApplication {
  id               String    @id @default(cuid())
  applicantId      String?
  businessType     String // "restaurant" | "cafe" | "lounge" | "rooftop" | "beach_club" | "experience"
  name             String
  contactName      String
  contactEmail     String
  contactPhone     String?
  description      String?
  // Full listing data captured up front, so approving an application can
  // mint a complete, ready-to-list Venue with no follow-up data entry.
  venue            String? // street address
  area             String?
  lat              Float?
  lng              Float?
  coverImage       String?
  photos           String[]
  guestTags        String[]
  priceRange       String?
  subscriptionTier String? // "basic" (OMR 5/mo) | "growth" (OMR 15/mo) | "premium" (OMR 30/mo) — see PLANS in HostVenue.tsx for feature breakdown
  // Ownership verification — the applicant must prove they own or operate
  // the venue before it can be listed. proofDocUrl is an uploaded photo of a
  // trade licence / commercial registration / authorization letter; role +
  // businessRegNo are their attestation, checked by a human at review.
  role             String? // "owner" | "manager" | "authorized"
  businessRegNo    String?
  proofDocUrl      String?
  // Step-6 schedule as entered by the applicant: [{ dayOfWeek, startTime,
  // endTime, capacity }]. Approval turns these into real
  // VenueAvailabilitySlot rows so the owner never re-enters their hours.
  availability     Json?
  status           String    @default("pending") // "pending" | "approved" | "rejected"
  // Admin review trail.
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNote       String?
  resultingVenueId String? // the Venue created when this application was approved
  createdAt        DateTime  @default(now())

  applicant User? @relation(fields: [applicantId], references: [id])

  @@index([status])
  @@index([applicantId])
}

// ============================================================
// Organizer Pro monetization layer.
//
// Ship state (see handoff.md for the full writeup): every organizer is
// currently auto-granted an ACTIVE subscription to the "pro" plan for
// free — see db.ensureSubscription() in server/db.js — so every feature
// flag below already resolves true for every real user. hasFeature()
// (server/features.js) is the one place that decides that, and is what
// every Pro-gated code path calls; nothing checks Subscription.status
// directly. No payment processor is wired to actually create/charge a
// subscription yet — see the "Stripe integration, parked" section of
// handoff.md for the architecture to wire in when that's turned on. This
// schema, and hasFeature()'s shape, doesn't change when that happens —
// only ensureSubscription()'s default plan/status does.
// ============================================================

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
  TRIALING
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  key           String   @unique // "free" | "pro"
  name          String
  priceOmr      Float
  billingPeriod String   @default("month")
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
  featureAccess FeatureAccess[]
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique // one subscription per organizer account
  planId                 String
  status                 SubscriptionStatus @default(INACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  // Cancel-flow exit survey (see /api/me/subscription/cancel) — captured
  // whether or not a save offer is ultimately accepted, so reason
  // distribution can be tracked even for saved customers, not just
  // completed cancellations.
  cancelReason           String?
  cancelFeedback         String?
  // Which save offer (if any) the organizer accepted last time they went
  // through the cancel flow — "pause" | "discount" | "downgrade" | null.
  // Analytics only today (offer-acceptance rate); once real billing exists,
  // "discount"/"downgrade" acceptance should also trigger the matching
  // Stripe action.
  retentionOfferAccepted String?
  // Set by the "pause" save offer — subscription.status flips to SUSPENDED
  // (see server/features.js's isActive(), unchanged: SUSPENDED already
  // reads as "not active" there) until this date, then ensureSubscription()
  // auto-resumes it back to ACTIVE on next read.
  pausedUntil            DateTime?
  // Populated once real billing is wired — null for every row created by
  // the current free-grant path. stripeSubscriptionId is the natural
  // dedup/idempotency key for webhook-driven updates (see BillingEvent).
  stripeCustomerId       String?
  stripeSubscriptionId   String?            @unique
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  plan           SubscriptionPlan @relation(fields: [planId], references: [id])
  billingEvents  BillingEvent[]
  paymentHistory PaymentHistory[]

  @@index([status])
  @@index([planId])
}

// Plan -> feature matrix, not a per-user table — every organizer on the
// same plan gets the same features, so this is a small, cacheable lookup
// (~25 rows total) rather than one row per user per feature. hasFeature()
// resolves userId -> Subscription.planId -> this table.
model FeatureAccess {
  id      String  @id @default(cuid())
  planId  String
  feature String // matches a key in server/features.js's FEATURES catalog
  enabled Boolean @default(true)

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@unique([planId, feature])
  @@index([feature])
}

// Raw provider webhook log — the dedup + replay-protection mechanism.
// providerEventId is unique so a redelivered Stripe webhook (Stripe
// explicitly recommends coding for at-least-once delivery) can't be
// processed twice; a handler checks for an existing row with the same id
// before acting, then writes processedAt once it has.
model BillingEvent {
  id              String    @id @default(cuid())
  subscriptionId  String?
  providerEventId String    @unique
  provider        String    @default("stripe")
  type            String // e.g. "invoice.paid", "customer.subscription.updated"
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([type])
}

model PaymentHistory {
  id             String    @id @default(cuid())
  subscriptionId String
  amountOmr      Float
  status         String // "paid" | "failed" | "refunded"
  providerRef    String? // Stripe payment_intent / invoice id
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
}

// ---- promo codes (covers promoCodes / discountCampaigns / earlyBirdCampaigns
// from the feature list — one model, a campaign is just a code with a
// date window, not a separate system) ----
model PromoCode {
  id            String    @id @default(cuid())
  eventId       String
  code          String // shown/entered as-is; uniqueness is scoped per event, not global
  discountType  String // "percent" | "flat"
  discountValue Float // percent: 0-100, flat: OMR amount
  maxUses       Int? // null = unlimited
  usedCount     Int       @default(0)
  // Group discounts: code only applies at checkout when cart qty >= this.
  // Null = no minimum (applies to any quantity), same as before this field.
  minQuantity   Int?
  startsAt      DateTime? // null = active immediately (early-bird window's open end)
  endsAt        DateTime? // null = no expiry
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, code])
}

// ---- marketing waitlist (waitlist.weynevents.com landing page) ----
// Deliberately separate from WaitlistEntry above — that one is a per-event
// sold-out-ticket waitlist tied to a real Event; this is a generic email
// capture with no relation to anything else in the schema.
model LandingWaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String? // "attendee" | "organizer" | "venue" — self-reported interest, optional
  source    String? // free-text: where they heard about it, or a UTM-ish tag
  createdAt DateTime @default(now())
}

// ---- waitlist (sold-out events) ----
model WaitlistEntry {
  id         String    @id @default(cuid())
  eventId    String
  email      String
  name       String?
  deviceId   String?
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?
  // Higher = notified first when capacity frees up. Written by the
  // "add_to_waitlist_priority" Event Workflows action (server/event-workflows.js) —
  // plain manual joins always default to 0.
  priority   Int       @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
}

// ---- AI Studio (Gemini-powered generation tools, "aiStudio" feature) ----
// Every call an organizer makes through AI Studio, logged for two reasons:
// visibility into what's actually being generated (moderation/support), and
// a real usage record if a per-generation quota is ever needed for a lower
// tier — not read by anything yet, but the alternative (adding it retroactively
// once usage actually matters) means losing all history from before that point.
model AiGenerationLog {
  id          String   @id @default(cuid())
  organizerId String
  eventId     String?
  feature     String // "description" | "pricing" | "cover-concept" | "summary"
  prompt      String
  output      String
  createdAt   DateTime @default(now())

  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizerId])
  @@index([eventId])
}

// One row per AI-proposed tool call — the approval gate for the agentic
// assistant (see server/agent-tools.js). Mirrors Campaign's existing
// "create as pending -> user approves/cancels -> executor runs it" shape
// rather than inventing a new state machine. Read-only tools never create
// a row here (see AGENT_TOOLS' `mutates` flag) — they execute immediately
// and their result just flows back into the conversation. Only tools that
// create/send/cancel something land here, and none of them touch the
// database until `status` moves to "approved".
model AgentAction {
  id          String    @id @default(cuid())
  organizerId String
  tool        String // e.g. "assignTable" | "createReservation" | "sendCampaignEmail"
  args        Json // the exact arguments the model proposed calling the tool with
  reasoning   String // the model's own explanation, shown to the owner before they approve
  status      String    @default("proposed") // "proposed" | "approved" | "rejected" | "executed" | "failed"
  result      Json? // set once executed — whatever the tool's real execution returned
  error       String? // set if execution failed after approval
  createdAt   DateTime  @default(now())
  decidedAt   DateTime?
  executedAt  DateTime?

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
  @@index([status])
}

// ---- Venue Management: an organizer's own reusable venue profiles ----
// Deliberately separate from the reservation-hosting `Venue` model (that
// one is for cafes/restaurants accepting table bookings from the public —
// a different product surface). This is a private library only the
// organizer who created it can see, picked from a dropdown in Event Builder.
model EventVenue {
  id                 String   @id @default(cuid())
  organizerId        String
  name               String
  address            String?
  lat                Float?
  lng                Float?
  capacity           Int?
  parkingAvailable   Boolean  @default(false)
  accessibilityNotes String?
  indoorOutdoor      String? // "indoor" | "outdoor" | "both"
  images             String[] @default([])
  notes              String?
  contacts           Json?
  supplierContacts   Json?
  createdAt          DateTime @default(now())

  organizer User    @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  events    Event[]

  @@index([organizerId])
}

// ---- Attendee CRM: a persistent profile per (organizer, email) ----
// Distinct from the computed cross-event spend rollup in db.organizerAttendees
// (that's read-only, derived from Booking every time) — this is where an
// organizer's own tags/notes/loyalty points actually live.
model AttendeeProfile {
  id            String    @id @default(cuid())
  organizerId   String
  email         String
  name          String?
  phone         String?
  tags          String[]  @default([])
  notes         String?
  loyaltyPoints Int       @default(0)
  birthday      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([organizerId, email])
  @@index([organizerId])
}

// ---- Messaging Center: scheduled + drip campaigns ----
// Extends the existing "send now" bulk-notify (POST /api/events/:id/notify)
// with a real scheduled/segment-targeted concept — sent by the same
// reminder-scan cron that already runs every 5 minutes, not a new worker.
model Campaign {
  id             String    @id @default(cuid())
  organizerId    String
  eventId        String? // set for event-ticket-buyer campaigns
  venueId        String? // set for venue-guest campaigns — exactly one of eventId/venueId is set, never both
  channel        String // "email" | "push"
  subject        String?
  message        String
  segment        Json? // e.g. {tags: ["vip"], minSpend: 50} — matched against AttendeeProfile/Booking (events) or VenueGuestNote/Reservation (venues)
  scheduledFor   DateTime?
  sentAt         DateTime?
  status         String    @default("scheduled") // scheduled | sent | cancelled
  // Set once actually sent — how many people it reached. A count computed
  // fresh from current data would drift from what was true at send time
  // (guests/attendees keep changing), so this is captured once and never
  // recomputed, same reasoning as any other historical ledger entry.
  recipientCount Int?
  createdAt      DateTime  @default(now())

  organizer  User                     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event      Event?                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue      Venue?                   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  recipients VenueCampaignRecipient[]

  @@index([organizerId])
  @@index([eventId])
  @@index([venueId])
  @@index([status, scheduledFor])
}

// Snapshot of exactly which guest emails a venue campaign was sent to, at
// the moment it sent — needed for win-back conversion tracking (did this
// specific guest book again after this specific send). Only populated for
// venue campaigns (Campaign.venueId set); the guest list resolved fresh at
// send time via resolveVenueSegment() would otherwise be un-recoverable
// after the fact since guest history keeps changing.
model VenueCampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  guestEmail String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([guestEmail])
}

// Reusable subject/message pairs for the bulk-notify form — saved on demand
// from NotifyForm, org-wide (not per-event) since the same "sold out, see
// you there" message is useful across many events.
model MessageTemplate {
  id          String   @id @default(cuid())
  organizerId String
  name        String
  subject     String?
  message     String
  createdAt   DateTime @default(now())

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
}

// ---- Financial Dashboard: manual expense tracking ----
// Revenue is already fully derivable from Booking/Payment (see
// db.organizerFinance) — expenses have no equivalent source, since Weyn
// never processes an organizer's actual costs, so this is the one genuinely
// new financial primitive: manually logged, not synced from anywhere.
model Expense {
  id          String   @id @default(cuid())
  organizerId String
  eventId     String?
  category    String
  amount      Float
  note        String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizerId])
  @@index([eventId])
}

// ---- File Library ----
model MediaAsset {
  id          String   @id @default(cuid())
  organizerId String
  eventId     String?
  url         String
  type        String // "image" | "video" | "document"
  folder      String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())

  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizerId])
}

// ---- Sponsor Management ----
model Sponsor {
  id             String   @id @default(cuid())
  organizerId    String
  eventId        String?
  name           String
  contactEmail   String?
  contactPhone   String?
  contractUrl    String?
  logoUrl        String?
  amount         Float?
  deliverables   String[] @default([])
  status         String   @default("prospect") // prospect | confirmed | delivered
  // ---- Sponsor ROI tracking ----
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  leadsGenerated Int      @default(0)
  createdAt      DateTime @default(now())

  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizerId])
}

// ---- Vendor Management ----
model Vendor {
  id            String   @id @default(cuid())
  organizerId   String
  eventId       String?
  category      String // catering | photography | security | cleaning | entertainment | other
  name          String
  contactEmail  String?
  contactPhone  String?
  contractUrl   String?
  paymentStatus String   @default("pending")
  rating        Int?
  notes         String?
  createdAt     DateTime @default(now())

  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizerId])
}

// ---- Feedback Center: post-event surveys ----
model EventFeedback {
  id        String   @id @default(cuid())
  eventId   String
  bookingId String?
  rating    Int?
  npsScore  Int?
  comment   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ---- Automation Builder: simple IF/THEN rules over real platform events ----
// Evaluated by the same reminder-scan cron for time/threshold-based
// triggers; purchase-based triggers (e.g. "someone buys VIP") are checked
// inline at the moment of the relevant action instead of polled.
model AutomationRule {
  id          String    @id @default(cuid())
  organizerId String
  eventId     String?
  venueId     String? // set for venue-workflow rules (reservation_created/cancelled/guest_no_show), alongside the existing event-scoped triggers
  name        String
  trigger     String // events: "vip_purchase" | "capacity_threshold" | "sales_drop" | "waitlist_threshold" | "event_published" — venues: "reservation_created" | "reservation_cancelled" | "guest_no_show"
  action      String // events: "notify_staff" | "tag_attendee" | "send_email" — venues: "notify_owner" | "tag_guest" | "send_guest_email"
  config      Json? // e.g. venue rules: {minPartySize?, requireTag?, tag?, subject?, message?}
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())

  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue     Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([organizerId])
  @@index([venueId])
}

// ============================================================
// Workflows — the visual node-graph automation builder (venue-scoped for
// now, mirrors AutomationRule's venueId-only reach above). A graph is
// trigger node -> condition node(s) -> action node(s), edges expressing
// "and then" (a condition's children only run if it passes) and fan-out
// (multiple children off one node all run). Deliberately NOT modeling
// true if/else branching, loops, approvals, or scheduled/retry execution
// yet — this is the real, working core (build/save/execute a graph) the
// rest of the master automation-builder vision would extend, not the
// whole thing at once.
// ============================================================
model Workflow {
  id          String   @id @default(cuid())
  organizerId String
  venueId     String
  name        String
  enabled     Boolean  @default(true)
  // Node shape: {id, type: "trigger"|"condition"|"action", x, y, data: {...}}
  // — data's shape depends on type, validated server-side at save time
  // (see server/venue-workflows.js's NODE_SCHEMAS), not by a Prisma enum,
  // since the set of condition/action kinds is expected to grow.
  nodes       Json
  // Edge shape: {id, source, target} — source/target are node ids above.
  edges       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer User          @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  venue     Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  runs      WorkflowRun[]

  @@index([organizerId])
  @@index([venueId])
}

// One row per time a workflow's trigger fired — the "execution logs /
// debug mode" from the master automation-builder prompt. `matchedActions`
// records which action nodes actually ran (a condition further up the
// graph may have stopped some branches) so an owner can see exactly why a
// run did or didn't do what they expected, not just that it ran.
model WorkflowRun {
  id             String   @id @default(cuid())
  workflowId     String
  trigger        String
  reservationId  String?
  matchedActions Json // array of {nodeId, action, ok, error?}
  status         String // "success" | "partial" | "failed"
  createdAt      DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

// ============================================================
// Event Workflows — the organizer-dashboard equivalent of Workflow/
// WorkflowRun above, for full parity with the venue side. Deliberately a
// PARALLEL model, not a polymorphic reuse of Workflow: Workflow.venueId is
// required with live prod rows, and the two domains (reservations/guests vs.
// tickets/tiers/promo codes) share almost no vocabulary — see
// server/event-workflows.js for the trigger/condition/action catalog and
// execution shape (same DFS walk/prune/chain as server/venue-workflows.js).
// ============================================================
model EventWorkflow {
  id          String   @id @default(cuid())
  organizerId String
  eventId     String
  name        String
  enabled     Boolean  @default(true)
  // Node shape: {id, type: "trigger"|"condition"|"action", x, y, data: {...}}
  nodes       Json
  // Edge shape: {id, source, target}
  edges       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer User               @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  runs      EventWorkflowRun[]

  @@index([organizerId])
  @@index([eventId])
}

model EventWorkflowRun {
  id             String   @id @default(cuid())
  workflowId     String
  trigger        String
  bookingId      String?
  matchedActions Json // array of {nodeId, action, ok, error?}
  status         String // "success" | "partial" | "failed"
  createdAt      DateTime @default(now())

  workflow EventWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

// ---- Organizer Goals ----
model OrganizerGoal {
  id             String @id @default(cuid())
  organizerId    String
  month          String // "2026-07"
  revenueGoal    Float?
  attendanceGoal Int?
  eventsGoal     Int?
  followersGoal  Int?

  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([organizerId, month])
}

// ============================================================
// Venue Marketing Hub — the venue-dashboard counterpart to the organizer
// side's MarketingLink/ReferralCode/OrganizerBrandKit (see those models'
// comments above). Deliberately separate models rather than reusing the
// organizer ones: those are FK'd to Event/organizerId, these are FK'd to
// Venue, and the two domains' feature flags are distinct keys in
// server/features.js (venue* prefix) so a venue owner's plan and an
// organizer's plan can differ independently. See server/app.js's
// "/api/venues/:id/marketing-links" etc. and server/venue-marketing.js.
// ============================================================

// UTM link builder — mirrors MarketingLink but points at a venue's public
// page instead of an event's. clicks starts at 0 and isn't incremented by
// anything yet (no redirect-through route exists), same as the organizer
// side's link builder today — the table exists so a venue owner has one
// place to keep the trackable links they've handed out.
model VenueMarketingLink {
  id          String   @id @default(cuid())
  venueId     String
  label       String
  utmSource   String
  utmMedium   String
  utmCampaign String
  url         String
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

// Loyalty/referral tracking per (venue, guest) — a punch-card-style tier
// (bronze/silver/gold) computed live from Reservation history at read time
// (see server/venue-marketing.js's loyaltyTierForVisits) rather than stored
// here, so it never drifts from the real reservation ledger; only the
// referral code itself (which must be stable/shareable once issued) is
// persisted. No payment/discount processing — this is tracking + a badge
// shown in the guest CRM, nothing more.
model VenueLoyalty {
  id            String   @id @default(cuid())
  venueId       String
  guestEmail    String
  referralCode  String   @unique
  referralCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, guestEmail])
  @@index([venueId])
}

// Per-venue branding preferences feeding into the AI campaign-copy prompt
// (server/venue-marketing.js's brandKitLine, reused from server/marketing.js's
// organizer equivalent) — same shape as OrganizerBrandKit, keyed by venueId
// instead of organizerId since one owner can run several venues with
// different branding each.
model VenueBrandKit {
  venueId      String   @id
  logoUrl      String?
  primaryColor String?
  toneOfVoice  String?
  updatedAt    DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}
