// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  avatarUrl    String?
  googleSub    String?   @unique
  // Default is ATTENDEE, not ORGANIZER — hosting is granted by *acting* as an
  // organizer (Event.ownerId is set the moment you create your first event),
  // not by the role column. Keeping the default minimal-privilege means a
  // brand-new session token has the least power a bug in `role` checks could
  // grant. ADMIN is manually assigned, never self-assigned.
  role         Role      @default(ATTENDEE)
  // Bumped to force-invalidate every outstanding session JWT for this user
  // (ban, role change, "sign out everywhere") — see auth.js's attachUser,
  // which rejects a token whose embedded tv doesn't match the current value.
  tokenVersion Int       @default(0)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  events          Event[]
  analyticsEvents AnalyticsEvent[]
  auditLogs       AuditLog[]
  teamMemberships EventTeamMember[] @relation("TeamMembership")
  teamInvitesSent EventTeamMember[] @relation("TeamInviter")
  following       Follow[]          @relation("Follower")
  followers       Follow[]          @relation("Following")
  collections     Collection[]
  reportsFiled    Report[]          @relation("Reporter")
  reportsReviewed Report[]          @relation("ReportReviewer")

  @@index([email])
}

// User → organizer (User who owns events) follow graph. Deliberately
// User-to-User, not User-to-Event — `Event.ownerId` already IS the real
// organizer identity, "organizer" the string field is just a display name.
// Following an organizer surfaces their future events, not just this one.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

// Pinterest-style named list of saved events. Public by default (link is
// shareable) — collaborative editing (multiple owners) is a real future
// step, deliberately not built now since no organizer/user has asked for it
// yet (see the "defer until needed" call on promo codes/UTM this round).
model Collection {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  owner User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([ownerId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  eventId      String
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([collectionId, eventId])
  @@index([eventId])
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  FRAUD
  DUPLICATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

// User-filed reports on an event/organizer/user, reviewed by an ADMIN via
// the moderation queue. entityType/entityId mirrors AuditLog's pattern
// rather than three separate nullable foreign keys.
model Report {
  id         String       @id @default(cuid())
  reporterId String?
  entityType String // "event" | "organizer" | "user"
  entityId   String
  reason     ReportReason
  note       String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  reviewedBy String?
  reviewedAt DateTime?

  reporter User? @relation("Reporter", fields: [reporterId], references: [id])
  reviewer User? @relation("ReportReviewer", fields: [reviewedBy], references: [id])

  @@index([entityType, entityId])
  @@index([status])
}

model Category {
  id    String  @id @default(cuid())
  key   String  @unique // "music", "sports" — matches Event.cat, validated against this table
  label String
  icon  String?
}

model Event {
  id                    String    @id
  title                 String
  organizer             String
  // ownerId is the real, enforced identity (nullable only for pre-auth seed
  // data — see migration notes). `organizer` stays as the display name so
  // existing frontend code and old data keep working unchanged.
  ownerId               String?
  cat                   String
  startsAt              DateTime
  endsAt                DateTime?
  venue                 String
  area                  String
  lat                   Float
  lng                   Float
  distanceKm            Float
  price                 Float
  capacity              Int
  sold                  Int       @default(0)
  image                 String?
  // "50% 30%" CSS background-position — Groq vision's best guess at the
  // photo's focal point, so cover crops (card/detail/dashboard, each a
  // different aspect ratio) don't just default to a dead-center crop that
  // might cut off the actual subject. Null = plain center crop.
  imageFocalPoint       String?
  color                 String
  glyph                 String
  blurb                 String
  tags                  String[]
  refundPolicy          String
  minAge                Int       @default(0)
  cancelled             Boolean   @default(false)
  ticketingType         String    @default("weyn")
  externalTicketUrl     String?
  organizerContact      String?
  sourceUrl             String?
  importedFromInstagram Boolean   @default(false)
  createdAt             DateTime  @default(now())
  deletedAt             DateTime? // soft delete — reads filter this out by default

  // Trust & safety: which discovery surfaces this event is eligible for.
  // Never gates event creation — only how widely it's shown. See
  // server/moderation.js for the pipeline that sets this.
  discoveryStatus DiscoveryStatus @default(PENDING_REVIEW)

  owner             User?              @relation(fields: [ownerId], references: [id])
  tiers             Tier[]
  bookings          Booking[]
  tickets           Ticket[]
  teamMembers       EventTeamMember[]
  collectionItems   CollectionItem[]
  moderationResults ModerationResult[]

  @@index([organizer])
  @@index([startsAt])
  @@index([ownerId])
  @@index([discoveryStatus])
}

enum DiscoveryStatus {
  PENDING_REVIEW // published, rule engine/AI review in flight — visible only via direct link
  APPROVED // full discovery feed, search, category browse
  DISCOVERY_LIMITED // direct link + organizer profile only, excluded from main feed/trending
  MANUAL_REVIEW // queued for a human — same visibility as DISCOVERY_LIMITED while pending
  DISCOVERY_BLOCKED // hidden everywhere, including direct link
}

// One row per moderation pass (rule engine and/or AI), so an event's full
// review history is auditable, not just its current status. See
// server/moderation.js's runModerationPipeline.
model ModerationResult {
  id              String          @id @default(cuid())
  eventId         String
  triggeredBy     String // "publish" | "edit" | "manual_recheck"
  ruleFlags       String[] // deterministic rule-engine flags that fired (soft-fail/warning)
  qualityScore    Int?
  trustScore      Int?
  spamRisk        Int?
  fraudRisk       Int?
  aiConfidence    Int?
  aiFlags         String[]
  reasoning       String[]
  aiConfigured    Boolean         @default(false) // false = heuristic fallback was used, not a real AI call
  resultingStatus DiscoveryStatus
  createdAt       DateTime        @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

enum TeamRole {
  // Same event powers as the owner (edit/cancel/duplicate/attendees/
  // marketing) except transferring ownership or managing the team itself —
  // that stays owner (or platform ADMIN) only, so a MANAGER can't remove the
  // person who invited them.
  MANAGER
  // Check-in only — the door-staff role. Deliberately can't see revenue,
  // attendee emails, or edit the event; scope matches what someone handed a
  // phone at the entrance actually needs.
  STAFF
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Grants a User (or a not-yet-registered email) scoped access to one Event
// without making them its owner. Invites are copy-link based, not emailed —
// Weyn has no transactional email provider configured; the organizer shares
// the link themselves (WhatsApp, email, however). userId is null until the
// invitee signs in and accepts, at which point it's filled in and the
// invite becomes the durable record of that person's access to this event.
model EventTeamMember {
  id           String           @id @default(cuid())
  eventId      String
  invitedEmail String
  userId       String?
  role         TeamRole
  status       TeamInviteStatus @default(PENDING)
  // Unguessable, single-use — the accept link is /invite/:inviteToken.
  // Cleared (set null) once accepted so a leaked old link can't be reused
  // to re-grant access after acceptance.
  inviteToken  String?          @unique @default(cuid())
  invitedBy    String
  createdAt    DateTime         @default(now())
  acceptedAt   DateTime?

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User? @relation("TeamMembership", fields: [userId], references: [id])
  inviter User  @relation("TeamInviter", fields: [invitedBy], references: [id])

  // one active (non-revoked) membership per person per event — re-inviting
  // after a revoke creates a new row rather than fighting a unique index
  @@index([eventId])
  @@index([userId])
  @@index([invitedEmail])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String // "event_view" | "event_save" | "search" | "category_click" | "profile_visit"
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([type, createdAt])
  @@index([entityId])
}

model Tier {
  id       String @id @default(cuid())
  eventId  String
  name     String
  price    Float
  capacity Int
  sold     Int    @default(0)

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([eventId])
}

enum BookingStatus {
  pending
  paid
  cancelled
  expired
}

model Booking {
  id       String        @id @default(cuid())
  eventId  String
  tierId   String?
  status   BookingStatus @default(pending)
  deviceId String?
  email    String?
  name     String?
  qty      Int           @default(1)
  bookedAt DateTime      @default(now())
  reminded Boolean       @default(false)

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier    Tier?    @relation(fields: [tierId], references: [id])
  payment Payment?
  tickets Ticket[]

  @@index([eventId])
  @@index([deviceId])
  @@index([status])
}

enum PaymentStatus {
  pending
  paid
  failed
}

model Payment {
  id             String        @id @default(cuid())
  bookingId      String        @unique
  paytabsTranRef String?       @unique
  amount         Float
  status         PaymentStatus @default(pending)
  rawWebhook     Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// One row per admitted seat (booking.qty can be >1) — the actual unit that
// gets scanned at the door. Deliberately separate from Booking so a
// multi-ticket purchase can't be checked in "all at once" by reusing a
// single shared code, and so a leaked/screenshotted code only ever admits
// one person, once.
model Ticket {
  id          String    @id @default(cuid())
  bookingId   String
  eventId     String
  // Long, random, unguessable — rendered as a QR code client-side. Not
  // sequential/derivable from the booking id, so scraping booking IDs can't
  // be used to forge admission.
  code        String    @unique @default(cuid())
  checkedInAt DateTime?
  checkedInBy String? // User.id of the organizer/staff who scanned it
  createdAt   DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([eventId])
}

// Append-only trail for anything that mutates state on someone else's
// behalf or destroys data — moderation, cancellation, check-in. Not meant
// to be edited or deleted by app code; exists purely for after-the-fact
// "who did what" review (disputes, fraud investigation, abuse reports).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String // e.g. "event.cancel", "event.moderate", "ticket.checkin"
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model PushToken {
  id           String   @id @default(cuid())
  deviceId     String   @unique
  token        String
  platform     String   @default("ios")
  registeredAt DateTime @default(now())
}

model MarketingAsset {
  eventId     String   @id
  instagram   String
  whatsapp    String
  telegram    String
  twitter     String
  generatedAt DateTime @default(now())
  aiGenerated Boolean  @default(false)
}
